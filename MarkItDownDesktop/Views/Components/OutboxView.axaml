<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MarkItDownDesktop.ViewModels"
             xmlns:models="using:MarkItDownDesktop.Models"
             xmlns:userControls="using:MarkItDownDesktop.Views.Components"
             x:Class="MarkItDownDesktop.Views.Components.OutboxView"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#555558" />
        </Style> 
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,16">
            <Border Grid.Column="0" Background="#252528" CornerRadius="8" Padding="3" BorderBrush="#333335"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding SelectFileViewCommand}"
                            Classes.ToggleActive="{Binding !IsCodeViewActive}"
                            Classes.ToggleInactive="{Binding IsCodeViewActive}"
                            Content="File View" Padding="16,8"
                            CornerRadius="6" BorderThickness="0" />

                    <Button Command="{Binding SelectCodeViewCommand}"
                            IsEnabled="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Classes.ToggleActive="{Binding IsCodeViewActive}"
                            Classes.ToggleInactive="{Binding !IsCodeViewActive}"
                            Content="Code View" Padding="16,8"
                            CornerRadius="6" BorderThickness="0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="#252528" CornerRadius="12" ClipToBounds="True">
            <Panel>
                <Rectangle Stroke="#444446" StrokeThickness="2" RadiusX="12" RadiusY="12" Margin="2" />
                <Grid Margin="12">
                    <!-- VIEW: File View -->
                    <ListBox Name="OutputListBox"
                             SelectionChanged="OnOutputListBoxSelectionChanged"
                             PointerReleased="OnOutputListBoxPointerReleased"
                             PointerMoved="OnOutputListBoxPointerMoved"
                             IsVisible="{Binding !IsCodeViewActive}"
                             ItemsSource="{Binding ConvertedFiles}"
                             SelectionMode="Multiple"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0" />
                            </Style>

                            <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>

                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                            <Style Selector="ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>

                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="#0A84FF" />
                                <Setter Property="Background" Value="#222225" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                            <Style
                                Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="#0A84FF" />
                                <Setter Property="Background" Value="#252528" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                            <Style
                                Selector="ListBoxItem:selected:focus /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="#0A84FF" />
                                <Setter Property="Background" Value="#252528" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                            <Style
                                Selector="ListBoxItem:selected:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="BorderBrush" Value="#0A84FF" />
                                <Setter Property="Background" Value="#252528" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="8" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ConvertedFile">
                                <Border Background="#1C1C1E" BorderBrush="#2D2D30" CornerRadius="8" Padding="14,12"
                                        BorderThickness="1" Cursor="Hand">
                                    <userControls:FileItemControl IsOutbox="True" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- VIEW: Code View -->
                    <TextBox IsVisible="{Binding IsCodeViewActive}"
                             Text="{Binding CodeViewText}"
                             IsReadOnly="True"
                             IsEnabled="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNotNull}}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas, Cascadia Code, monospace"
                             FontSize="13"
                             Background="Transparent"
                             Foreground="#E1E1E6"
                             BorderThickness="0"
                             Padding="8"
                             Margin="4" />

                    <!-- TODO: MD viewer -->
                </Grid>
            </Panel>
        </Border>
    </Grid>
</UserControl>