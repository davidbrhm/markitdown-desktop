<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MarkItDownDesktop.ViewModels"
             xmlns:models="using:MarkItDownDesktop.Models"
             xmlns:userControls="using:MarkItDownDesktop.Views.Components"
             x:Class="MarkItDownDesktop.Views.Components.InboxView"
             x:DataType="vm:MainWindowViewModel">

    <Grid DragDrop.AllowDrop="True" DragDrop.DragOver="OnDragOver" DragDrop.Drop="OnDrop">
        <Border Name="DragDropBorder" Background="#252528" CornerRadius="12" ClipToBounds="True"
                PointerPressed="OnDragDropBorderPointerPressed" Cursor="Hand">
            <Panel>
                <!-- Dashed border -->
                <Rectangle Stroke="#444446" StrokeDashArray="4,4" StrokeThickness="2"
                           RadiusX="12" RadiusY="12" Margin="2" />
                <!-- Empty state -->
                <StackPanel IsVisible="{Binding !HasFiles}" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="16">
                    <Viewbox Width="64" Height="64">
                        <Path Fill="#A1A1A6"
                              Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm-2 16l-4-4h3V10h2v4h3l-4 4zm1-9V3.5L18.5 9H13z" />
                    </Viewbox>
                    <TextBlock Text="Drag &amp; Drop File Here" FontSize="18" FontWeight="SemiBold"
                               Foreground="#FFFFFF" HorizontalAlignment="Center" />
                    <TextBlock Text="Supported: PDF, DOCX, XLSX, PPTX, HTML, Audio, Images" FontSize="12"
                               Foreground="#A1A1A6" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                               TextAlignment="Center" />
                </StackPanel>

                <!-- Directory state -->
                <ScrollViewer IsVisible="{Binding HasFiles}" Margin="16">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*, Auto" Margin="4,0,0,8">
                            <TextBlock Grid.Column="0" Text="Inbox Files" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#A1A1A6" VerticalAlignment="Center" />

                            <Button Grid.Column="1" Command="{Binding ClearWorkspaceCommand}"
                                    Background="Transparent" BorderThickness="0" Padding="8,4" Cursor="Hand">
                                <Path Fill="#FF453A"
                                      Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                      Width="14" Height="14" Stretch="Uniform" />
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#321212" />
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ConvertedFiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ConvertedFile">
                                    <Border Background="#1C1C1E" CornerRadius="8" Padding="14,12"
                                            BorderBrush="#2D2D30" BorderThickness="1" Cursor="Hand">
                                        <userControls:FileItemControl IsOutbox="False" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Panel>
        </Border>
    </Grid>
</UserControl>