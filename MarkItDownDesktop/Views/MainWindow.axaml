<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MarkItDownDesktop.ViewModels"
        xmlns:userControls="using:MarkItDownDesktop.Views.Components"
        x:Class="MarkItDownDesktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MarkItDown Desktop" Width="1100" Height="650" MinWidth="750" MinHeight="450"
        Background="#1C1C1E" RequestedThemeVariant="Dark" WindowStartupLocation="CenterScreen"
        KeyDown="OnWindowKeyDown">

    <Window.Styles>
        <Style Selector="Button.ToggleActive">
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.ToggleInactive">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#A1A1A6" />
        </Style>
        <Style Selector="Button.ToggleInactive:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#252528" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="*, 8, *" Margin="24">
        <userControls:InboxView Grid.Column="0" />

        <GridSplitter Grid.Column="1" Background="Transparent" Width="8" />

        <userControls:OutboxView x:Name="OutboxComponent" Grid.Column="2" />
    </Grid>
</Window>